# PostgreSQL password (required, choose a strong random password)
POSTGRES_PASSWORD=change-me-to-a-secure-password

# Embedding model (must match a directory in ./models/)
EMBEDDINGS_MODEL=multilingual-e5-large

# Server port (default: 3000)
# MCP_PORT=3000

# Trust proxy level for rate limiting behind a reverse proxy (default: 0 = disabled)
# Set to 1 if behind one proxy (e.g., nginx, Caddy), 2 for two proxies, etc.
# TRUST_PROXY=0
