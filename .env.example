# PostgreSQL password (required, choose a strong random password)
POSTGRES_PASSWORD=change-me-to-a-secure-password

# Embedding model (must match a directory in ./models/)
EMBEDDINGS_MODEL=multilingual-e5-large

# Server port (default: 3000)
# MCP_PORT=3000

# Trust proxy level for rate limiting behind a reverse proxy (default: 0 = disabled)
# Set to 1 if behind one proxy (e.g., nginx, Caddy), 2 for two proxies, etc.
# TRUST_PROXY=0

# --- Authentication (both optional, disable for local-only use) ---

# Static API key for CLI clients (e.g., Claude Code)
# Generate one: openssl rand -base64 32
# MCP_API_KEY=your-secret-api-key

# PIN for OAuth 2.1 consent (e.g., claude.ai, mobile clients)
# When set, web clients authenticate via a PIN entry page.
# MCP_AUTH_PIN=123456

# Public URL of the server (required for OAuth, so clients can reach the consent page)
# MCP_BASE_URL=https://your-server.example.com
